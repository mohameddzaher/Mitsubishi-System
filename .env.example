# Copy to `.env.local` for local dev, and set these same vars in your host's
# dashboard for production (Netlify: Site settings → Environment variables).

# --- MongoDB (use MongoDB Atlas in production) ---
MONGODB_URI="mongodb+srv://USER:PASS@CLUSTER.mongodb.net/?retryWrites=true&w=majority&appName=Mitsubishi-DB"
MONGODB_DB="melsa_mecca"

# --- Auth.js v5 ---
# AUTH_SECRET: generate with `openssl rand -base64 48` — unique per environment
AUTH_SECRET="generate-with-openssl-rand-base64-48"
# AUTH_URL: canonical public URL of the deployed app (no trailing slash)
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# --- App (NEXT_PUBLIC_* vars ship to the browser) ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="MELSA Mecca"
NEXT_PUBLIC_BRANCH_CODE="MKK"

# --- Pusher (real-time) ---
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="eu"
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="eu"

# --- Email (Resend) ---
RESEND_API_KEY=""
RESEND_FROM="MELSA Mecca <noreply@melsa-mkk.com>"

# --- Storage (R2 / S3) ---
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="melsa-mecca"
R2_PUBLIC_URL=""

# --- Google Maps ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# --- Cron security ---
# CRON_SECRET: generate with `openssl rand -base64 48`
# Call cron routes with header: Authorization: Bearer $CRON_SECRET
CRON_SECRET="generate-with-openssl-rand-base64-48"
